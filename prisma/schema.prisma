generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

enum UserRole {
  MASTER
  AGENTE
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  telefone  String?
  password  String
  role               UserRole @default(AGENTE)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt DateTime @updatedAt

  notas       Nota[]
  kanbanCards KanbanCard[]
  campanhas   Campanha[]
}

// ─────────────────────────────────────────
// EMPRESAS
// ─────────────────────────────────────────

model Empresa {
  nif           String  @id // PT + 9 dígitos, ex: PT123456789
  nome          String
  telefone      String?
  email         String?
  website       String?
  morada        String?
  distrito      String?
  localidade    String?
  quemAtende    String?
  responsavel   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rascunho        Boolean  @default(false)
  importProblemas String?  // razões de importação problemática (JSON)

  nomeComercial        String?   // nome fiscal registado no NIF.pt (preenchido pelo enriquecimento)

  enriquecimentoStatus String?   // "encontrado" | "sem_contactos" | "sem_dados" | "nif_invalido"
  enriquecimentoRaw    String?   // JSON raw da resposta NIF.pt
  enriquecimentoAt     DateTime? // quando foi pesquisado

  notas        Nota[]
  instalacoes  Instalacao[]
  kanbanCard   KanbanCard?
  enviosEmail  EnvioEmail[]
}

// ─────────────────────────────────────────
// NOTAS (timestampadas por empresa + user)
// ─────────────────────────────────────────

model Nota {
  id         String   @id @default(cuid())
  texto      String
  createdAt  DateTime @default(now())

  empresaNif String
  empresa    Empresa  @relation(fields: [empresaNif], references: [nif])

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// INSTALAÇÕES
// ─────────────────────────────────────────

enum TipoInstalacao {
  MAT
  AT
  MT
  BTE
  BTN
}

enum CicloTarifario {
  SIMPLES
  BI_HORARIO
  TRI_HORARIO
  DIARIO
  SEMANAL
  SEMANAL_OPCIONAL
}

model Instalacao {
  id                  String          @id @default(cuid())
  cpe                 String          @unique
  morada              String?
  tipoInstalacao      TipoInstalacao
  cicloTarifario      CicloTarifario?
  dataInicioContrato  DateTime?
  mesTermino          String?         // ex: "2025-12"
  fornecedor          String?

  // Consumos em kWh
  consumoPonta        Float?
  consumoCheia        Float?
  consumoVazio        Float?
  consumoSVazio       Float?
  consumoAnual        Float?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  empresaNif          String
  empresa             Empresa         @relation(fields: [empresaNif], references: [nif])
}

// ─────────────────────────────────────────
// KANBAN CARDS
// ─────────────────────────────────────────

enum KanbanColuna {
  EM_REVISAO
  PRIMEIRO_CONTACTO
  ENVIAR_EMAIL
  EM_CONTACTO
  PROPOSTA
  CLIENTE
}

model KanbanCard {
  id                  String       @id @default(cuid())
  coluna              KanbanColuna @default(PRIMEIRO_CONTACTO)

  // Agendamento de próximo contacto
  agendamentoData     DateTime?
  agendamentoNota     String?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Empresa bloqueada por este user
  empresaNif          String       @unique
  empresa             Empresa      @relation(fields: [empresaNif], references: [nif])

  userId              String
  user                User         @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// EMAIL OUTREACH
// ─────────────────────────────────────────

model ContaEmailSMTP {
  id              String   @id @default(cuid())
  nome            String
  host            String
  porta           Int
  usuario         String
  passwordCifrada String
  assinaturaHtml  String?
  limiteDiario    Int      @default(950)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campanhas       Campanha[]
}

model ModeloEmail {
  id        String   @id @default(cuid())
  nome      String
  assunto   String
  corpoHtml String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campanhas Campanha[]
}

enum CampanhaStatus {
  RASCUNHO
  A_ENVIAR
  PAUSADA_LIMITE
  CONCLUIDA
}

model Campanha {
  id            String         @id @default(cuid())
  nome          String
  mesFiltro     Int? // mês de início de contrato, 1-12 (independente do ano); nulo em campanhas de teste
  teste         Boolean        @default(false)
  status        CampanhaStatus @default(RASCUNHO)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  contaEmailId  String
  contaEmail    ContaEmailSMTP @relation(fields: [contaEmailId], references: [id])

  modeloEmailId String
  modeloEmail   ModeloEmail    @relation(fields: [modeloEmailId], references: [id])

  criadoPorId   String
  criadoPor     User           @relation(fields: [criadoPorId], references: [id])

  envios        EnvioEmail[]
}

enum EnvioStatus {
  PENDENTE
  ENVIANDO
  ENVIADO
  FALHOU
}

model EnvioEmail {
  id            String      @id @default(cuid())
  status        EnvioStatus @default(PENDENTE)
  trackingToken String      @unique @default(cuid())
  enviadoEm     DateTime?
  abertoEm      DateTime?
  erro          String?
  createdAt     DateTime    @default(now())

  campanhaId    String
  campanha      Campanha    @relation(fields: [campanhaId], references: [id])

  // Uma das duas é sempre preenchida: empresaNif (envio real) ou emailAvulso (envio de teste)
  empresaNif    String?
  empresa       Empresa?    @relation(fields: [empresaNif], references: [nif])
  emailAvulso   String?
}
